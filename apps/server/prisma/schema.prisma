// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Word {
  id         String   @id @default(uuid())
  term       String 
  definition String
  createdAt  DateTime @default(now())
}
